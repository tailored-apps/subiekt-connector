@page "/"
@using Subiekt.Connector.Sdk
@using Subiekt.Connector.Contracts
@inject SubiektClient Sdk

<h3>Klienci</h3>

@if (!Sdk.IsAuthorized)
{
    <div class="alert alert-warning">
        Nie jesteś zalogowany. <a href="auth">Przejdź do autoryzacji →</a>
    </div>
    return;
}

<div class="row mb-3 g-2">
    <div class="col-md-4">
        <input class="form-control" placeholder="Nazwa..." @bind="filterName" />
    </div>
    <div class="col-md-3">
        <select class="form-select" @bind="filterKind">
            <option value="">Wszystkie rodzaje</option>
            <option value="Company">Firma</option>
            <option value="Person">Osoba</option>
        </select>
    </div>
    <div class="col-md-3">
        <select class="form-select" @bind="sortBy">
            <option value="">Domyślne</option>
            <option value="name:asc">Nazwa A-Z</option>
            <option value="name:desc">Nazwa Z-A</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100" @onclick="Search" disabled="@loading">Szukaj</button>
    </div>
</div>

@if (loading)
{
    <p><span class="spinner-border spinner-border-sm"></span> Ładowanie...</p>
}
else if (error is not null)
{
    <div class="alert alert-danger">
        <strong>Błąd:</strong> @error
        <button class="btn btn-sm btn-outline-danger ms-2" @onclick="Search">Ponów</button>
    </div>
}
else
{
    <p class="text-muted small">Wyświetlono @clients.Count z @totalItems</p>
    <table class="table table-striped table-sm">
        <thead><tr><th>Nazwa</th><th>NIP</th><th>Rodzaj</th><th>Miasto</th><th>Grupa</th><th></th></tr></thead>
        <tbody>
            @foreach (var c in clients)
            {
                <tr>
                    <td><a href="klienci/@c.Id">@c.Name</a></td>
                    <td>@c.Tin</td>
                    <td>@(c.Kind == ClientKind.Company ? "Firma" : "Osoba")</td>
                    <td>@c.Address?.City</td>
                    <td>@c.Group</td>
                    <td><a href="klienci/@c.Id" class="btn btn-outline-primary btn-sm">Edytuj</a></td>
                </tr>
            }
        </tbody>
    </table>

    @if (clients.Count == 0)
    {
        <p class="text-muted">Brak klientów.</p>
    }
    else if (clients.Count < totalItems)
    {
        <button class="btn btn-outline-secondary btn-sm" @onclick="LoadMore">Załaduj więcej</button>
    }
}

@code {
    private List<ClientListItemDto> clients = [];
    private int totalItems;
    private bool loading = true;
    private string? error;
    private string filterName = "";
    private string filterKind = "";
    private string sortBy = "";
    private int page = 0;
    private const int PageSize = 25;

    protected override async Task OnInitializedAsync() => await LoadPage();

    private async Task Search()
    {
        page = 0;
        clients = [];
        await LoadPage();
    }

    private async Task LoadMore()
    {
        page++;
        await LoadPage();
    }

    private async Task LoadPage()
    {
        loading = true;
        error = null;
        StateHasChanged();
        try
        {
            var filters = BuildFilters();
            var order = string.IsNullOrEmpty(sortBy) ? null : new[] { sortBy };
            var result = await Sdk.Clients.ListAsync(page, PageSize, filters.Length > 0 ? filters : null, order);
            totalItems = result.TotalItemsCount;
            if (page == 0)
                clients = result.Items ?? [];
            else
                clients.AddRange(result.Items ?? []);
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    private string[] BuildFilters()
    {
        var f = new List<string>();
        if (!string.IsNullOrEmpty(filterName)) f.Add($"name~{filterName}");
        if (!string.IsNullOrEmpty(filterKind)) f.Add($"kind={filterKind}");
        return f.ToArray();
    }
}
