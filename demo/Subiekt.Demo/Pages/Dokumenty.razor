@page "/dokumenty"
@using Subiekt.Connector.Sdk
@using Subiekt.Connector.Contracts
@inject SubiektClient Sdk

<h3>Dokumenty</h3>

@if (!Sdk.IsAuthorized)
{
    <div class="alert alert-warning">
        Nie jesteś zalogowany. <a href="auth">Przejdź do autoryzacji →</a>
    </div>
    return;
}

<div class="row mb-3 g-2">
    <div class="col-md-3">
        <input class="form-control" placeholder="Klient..." @bind="filterClient" />
    </div>
    <div class="col-md-2">
        <input class="form-control" type="date" @bind="dateFrom" title="Od daty" />
    </div>
    <div class="col-md-2">
        <input class="form-control" type="date" @bind="dateTo" title="Do daty" />
    </div>
    <div class="col-md-2">
        <select class="form-select" @bind="sortBy">
            <option value="">Domyślne</option>
            <option value="issueDate:desc">Data wyst. malejąco</option>
            <option value="issueDate:asc">Data wyst. rosnąco</option>
            <option value="documentNumber:asc">Numer A-Z</option>
            <option value="documentNumber:desc">Numer Z-A</option>
        </select>
    </div>
    <div class="col-md-3 d-flex gap-2">
        <button class="btn btn-primary flex-grow-1" @onclick="Search" disabled="@loading">Szukaj</button>
        <button class="btn btn-outline-secondary" @onclick="ClearFilters" disabled="@loading">Wyczyść</button>
    </div>
</div>

@if (loading)
{
    <p><span class="spinner-border spinner-border-sm"></span> Ładowanie...</p>
}
else if (error is not null)
{
    <div class="alert alert-danger">
        <strong>Błąd:</strong> @error
        <button class="btn btn-sm btn-outline-danger ms-2" @onclick="Search">Ponów</button>
    </div>
}
else
{
    <p class="text-muted small">Wyświetlono @documents.Count z @totalItems</p>
    <table class="table table-striped table-sm">
        <thead>
            <tr>
                <th>Numer</th>
                <th>Rodzaj</th>
                <th>Klient</th>
                <th>Data wyst.</th>
                <th>Termin płatn.</th>
                <th>Brutto</th>
                <th>Pozostało</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in documents)
            {
                <tr>
                    <td><a href="dokumenty/@d.Id">@d.DocumentNumber</a></td>
                    <td><span class="badge bg-info text-dark">@d.Kind</span></td>
                    <td>@d.Client</td>
                    <td>@(d.IssueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                    <td>@(d.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                    <td class="text-end">@(d.TotalGross?.ToString("N2") ?? "-") @d.Currency</td>
                    <td class="text-end">@(d.LeftToPay?.ToString("N2") ?? "-")</td>
                    <td>
                        <span class="badge @PaymentBadge(d.PaymentState)">@PaymentLabel(d.PaymentState)</span>
                    </td>
                    <td><a href="dokumenty/@d.Id" class="btn btn-outline-primary btn-sm">Podgląd</a></td>
                </tr>
            }
        </tbody>
    </table>

    @if (documents.Count == 0)
    {
        <p class="text-muted">Brak dokumentów.</p>
    }
    else if (documents.Count < totalItems)
    {
        <button class="btn btn-outline-secondary btn-sm" @onclick="LoadMore">Załaduj więcej</button>
    }
}

@code {
    private List<DocumentListDto> documents = [];
    private int totalItems;
    private bool loading = true;
    private string? error;
    private string filterClient = "";
    private DateTime? dateFrom;
    private DateTime? dateTo;
    private string sortBy = "";
    private int page = 0;
    private const int PageSize = 25;

    protected override async Task OnInitializedAsync() => await LoadPage();

    private async Task Search()
    {
        page = 0;
        documents = [];
        await LoadPage();
    }

    private async Task ClearFilters()
    {
        filterClient = "";
        dateFrom = null;
        dateTo = null;
        sortBy = "";
        await Search();
    }

    private async Task LoadMore()
    {
        page++;
        await LoadPage();
    }

    private async Task LoadPage()
    {
        loading = true;
        error = null;
        StateHasChanged();
        try
        {
            var filters = BuildFilters();
            var order = string.IsNullOrEmpty(sortBy) ? null : new[] { sortBy };
            var result = await Sdk.Documents.ListAsync(page, PageSize, filters.Length > 0 ? filters : null, order);
            totalItems = result.TotalItemsCount;
            if (page == 0)
                documents = result.Items ?? [];
            else
                documents.AddRange(result.Items ?? []);
        }
        catch (Exception ex) { error = ex.Message; }
        finally { loading = false; }
    }

    private string[] BuildFilters()
    {
        var f = new List<string>();
        if (!string.IsNullOrEmpty(filterClient)) f.Add($"client~{filterClient}");
        if (dateFrom.HasValue) f.Add($"issueDate_From={dateFrom.Value:yyyy-MM-dd}");
        if (dateTo.HasValue) f.Add($"issueDate_To={dateTo.Value:yyyy-MM-dd}");
        return f.ToArray();
    }

    private static string PaymentBadge(PaymentState? state) => state switch
    {
        PaymentState.Paid => "bg-success",
        PaymentState.Unpaid => "bg-warning text-dark",
        PaymentState.Overdue => "bg-danger",
        _ => "bg-secondary"
    };

    private static string PaymentLabel(PaymentState? state) => state switch
    {
        PaymentState.Paid => "Zapłacony",
        PaymentState.Unpaid => "Niezapłacony",
        PaymentState.Overdue => "Przeterminowany",
        PaymentState.NotSubjectToPayment => "Nie podlega",
        _ => "-"
    };
}
